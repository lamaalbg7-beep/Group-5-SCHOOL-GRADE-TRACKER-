class Person: # Parent class 
    def __init__(self , name , person_id , age ):
        self.name = name
        self.person_id = person_id
        self.age = age

    def role(self):
        return ""

    def display(self):
        print(f"Name: {self.name} , ID: {self.person_id} , Age: {self.age}")


class Student(Person):
    def __init__(self, name, person_id, age):
        super().__init__(name, person_id, age)

        self._grades = {}

    def add_grade(self , subject, grade):
        if subject not in self._grades:
            self._grades[subject] = []
        self._grades[subject].append(grade)

    def gpa(self):
        total = 0
        count = 0
        for grades in self._grades.values():
            for grade in grades:
                total += grade
                count += 1
        if count == 0:
            return 0
        return total / count
    
    def report_card(self):
        for subject , grades in self._grades.items():
            avg = sum(grades) / len(grades)
            print(subject , avg)
        print("GPA:" , self.gpa())


class Teacher(Person):
    def __init__(self, name, person_id, age ,subject_taught):
        super().__init__(name, person_id, age)
        self.subject_taught = subject_taught

    def role(self):
        return "Teacher"
    
class School:
    def __init__(self):
        self.students = {}
        self.teachers = {}
        self.subject = set ()

    def add_student(self, student_obj):
        if student_obj.person_id in self.students:
            print("Error, this number is already registered.")
            return 
        
        self.students[student_obj.person_id] = student_obj
        print(f"Student {student_obj.name} added successfully")

    def add_teacher(self, teacher_obj):
        if teacher_obj.person_id in self.teachers:
            print("Error, this number is already registered.")
            return
        self.teachers[teacher_obj.person_id] = teacher_obj
        self.subject.add(teacher_obj.subject_taught)
        print(f"Teacher {teacher_obj.name} added for subject : {teacher_obj.subject_taught}.")
    def record_grade(self, student_id, subject, grade):
        if student_id not in self.students:
            print("Error student not found")
            return
        if subject not in self.subject:
            print(f"Error: Subject {subject} is not taught in this school")
            return
        
        if grade < 0 or grade > 100:
            raise ValueError("Grade out of range (must be 0-100)")
        self.students[student_id].add_grade(subject, grade)
        print(f"Grade {grade} recorded for student ID {student_id} in {subject}")
        if grade < 0 or grade > 100:
            raise ValueError("Grade out of range (must be 0-100)")
        
        self.students[student_id].add_grade(subject, grade)
        print(f"Grade {grade} recorded for student ID {student_id} in {subject}")

    def class_average(self, subject):
        total = 0
        count = 0
        
        for student in self.students.values():
            if hasattr(student, 'grades') and subject in student.grades:
                if isinstance(student.grades[subject], list):
                    for g in student.grades[subject]:
                        total += g
                        count += 1
                else:
                    total += student.grades[subject]
                    count += 1

        if count == 0:
            print(f"No grades found for '{subject}'.")
            return
            
        avg = total / count
        print(f"Class average for {subject}: {avg:.2f}")


